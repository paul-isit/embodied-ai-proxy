import argparse
import yaml
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent
sys.path.append(str(ROOT / "src"))

from backend.llm_proxy import LLMProxy

def load_tests(path):
    with open(path, "r") as f:
        data = yaml.safe_load(f)

    if isinstance(data, dict) and "tests" in data:
        return data["tests"]

    if isinstance(data, list):
        return data

    raise ValueError("Invalid test format")

def normalize(obj):
    if not isinstance(obj, dict):
        return {}

    return {
        "action": str(obj.get("action", "")).strip().lower(),
        "target": str(obj.get("target", "")).strip().lower(),
    }

def run_tests(proxy, tests):
    results = []

    for i, test in enumerate(tests, 1):

        if not isinstance(test, dict):
            print(f"\n[Test {i}] INVALID FORMAT")
            results.append(False)
            continue

        name = test.get("name", f"test_{i}")
        prompt = test.get("prompt", "")
        available_objects = test.get("available_objects", [])
        expected = test.get("expected", {})

        print(f"\n[Test {i}] {name}")

        try:
            result = proxy.generate(prompt, available_objects)

            parsed = result.get("parsed", {})

            expected_norm = normalize(expected)
            actual_norm = normalize(parsed)

            passed = expected_norm == actual_norm

            if passed:
                print("  Result: PASS")
            else:
                print("  Result: FAIL")

            print("  Expected:", expected_norm)
            print("  Got     :", actual_norm)

            results.append(passed)

        except Exception as e:
            print("  Result: FAIL (Exception)")
            print("  Expected:", normalize(expected))
            print("  Got     : None")
            print("  Error   :", str(e))
            results.append(False)

    return results

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--config-dir", required=True)
    parser.add_argument("--tests", required=True)

    args = parser.parse_args()

    print("--- Initializing LLM Proxy ---")
    proxy = LLMProxy(args.config_dir)
    print("Proxy initialized successfully.")

    tests = load_tests(args.tests)

    print("\n--- Running Tests ---")
    results = run_tests(proxy, tests)

    passed = sum(results)
    total = len(results)

    print("\n========================================")
    print(" BULK TEST SUMMARY")
    print("========================================")
    print(f" Total Tests Run : {total}")
    print(f" Passed          : {passed}")
    print(f" Failed          : {total - passed}")
    print("========================================")

if __name__ == "__main__":
    main()
