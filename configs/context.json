{
  "llm": {
    "provider": "ollama",
    "model": "llama3",
    "base_url": "http://localhost:11434",
    "api_key": "",
    "max_tokens": 512,
    "temperature": 0.2,
    "timeout_seconds": 30
  },
  "json_schema": {
    "required_fields": ["recipe_name", "steps"],
    "step_required_fields": ["step_id", "action"],
    "allowed_actions": ["home", "move_arm", "gripper", "relative_move"],
    "allowed_directions": ["move_upwards", "move_downwards", "move_left", "move_right"],
    "gripper_state": ["open", "closed"],
    "coordinates": {
      "x": { "type": "float", "min": 0.0, "max": 0.0 },
      "y": { "type": "float", "min": 0.0, "max": 0.0 },
      "z": { "type": "float", "min": 0.0, "max": 0.0 }
    }
  },
  "system_prompt_context": {
    "robot": "Kinova Gen3 lite",
    "instructions": "You are a robot controller. Always respond in valid JSON only. Never include explanation or extra text.",
    "workspace_description": "A tabletop environment with objects placed within arm reach",
    "response_format": {
      "recipe_name": "string",
      "steps": [
        {
          "step_id": "integer",
          "action": "string",
          "parameters": "object (optional)",
          "description": "string"
        }
      ]
    }
  }
}